---
import { formatDate, getArticleCategory, getArticleUrl, type Article } from '../lib/content';

type Props = {
  article: Article;
  featured?: boolean;
};

const { article, featured = false } = Astro.props;
const category = getArticleCategory(article);
---

<article class:list={['article-card', { featured }]}>
  {category && <a class="card-category" href={`/categories/${category.slug}/`}>{category.name}</a>}
  <h2><a href={getArticleUrl(article)}>{article.data.title}</a></h2>
  <p>{article.data.description}</p>
  <footer class="meta">
    <span>{formatDate(article.data.publishDate)}</span>
    <span>{article.data.type === 'news' ? 'Actu' : article.data.type}</span>
  </footer>
</article>

<style>
  .article-card {
    display: grid;
    align-content: start;
    gap: 12px;
    min-height: 100%;
    border-top: 3px solid var(--ink);
    padding: 18px 0 0;
  }

  .article-card.featured {
    border-top-color: var(--accent);
  }

  .card-category {
    width: fit-content;
    color: var(--accent-dark);
    font-size: 0.85rem;
    font-weight: 800;
    text-decoration: none;
  }

  h2 {
    margin: 0;
    color: var(--ink);
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(1.45rem, 4vw, 2.35rem);
    line-height: 1.06;
  }

  h2 a {
    text-decoration: none;
  }

  p {
    margin: 0;
    color: var(--muted);
  }

  footer {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
  }
</style>
