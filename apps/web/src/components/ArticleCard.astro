---
import { formatDate, getArticleCategory, getArticleUrl, type Article } from '../lib/content';

type Props = {
  article: Article;
  featured?: boolean;
};

const { article, featured = false } = Astro.props;
const category = getArticleCategory(article);
const typeLabels = {
  article: 'Article',
  news: 'Actu',
  guide: 'Guide',
  analysis: 'Analyse',
};
---

<article class:list={['article-card', 'article-card-shell', { featured }]}>
  <div class="card-topline">
    {category && <a class="category-tag" href={`/categories/${category.slug}/`}>{category.name}</a>}
    <span>{typeLabels[article.data.type]}</span>
  </div>
  <h2 class="card-title"><a href={getArticleUrl(article)}>{article.data.title}</a></h2>
  <p>{article.data.description}</p>
  <footer class="meta">
    <span>{formatDate(article.data.publishDate)}</span>
  </footer>
</article>

<style>
  .article-card {
    transform: rotate(-0.4deg);
  }

  .article-card.featured {
    background:
      linear-gradient(110deg, transparent 0 68%, color-mix(in oklch, var(--marker) 28%, transparent) 68% 100%),
      var(--paper);
    box-shadow: var(--shadow-paper-strong);
    transform: rotate(0.8deg);
  }

  .article-card:nth-child(3n) {
    transform: rotate(0.5deg);
  }

  .card-topline {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    justify-content: space-between;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 800;
  }

  h2 a {
    text-decoration: none;
  }

  h2 a:hover {
    text-decoration: underline;
    text-decoration-color: var(--marker);
    text-decoration-thickness: 0.25em;
    text-underline-offset: -0.12em;
    text-decoration-skip-ink: none;
  }

  p {
    margin: 0;
    color: var(--muted);
    text-wrap: pretty;
  }

  footer {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
  }
</style>
