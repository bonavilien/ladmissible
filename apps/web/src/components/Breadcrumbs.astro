---
type Props = {
  items: Array<{ name: string; path: string }>;
};

const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Fil d'Ariane">
  <ol>
    {items.map((item, index) => (
      <li>
        {index < items.length - 1 ? <a href={item.path}>{item.name}</a> : <span>{item.name}</span>}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumbs {
    color: var(--muted);
    font-size: 0.9rem;
  }

  ol {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li:not(:last-child)::after {
    content: "/";
    margin-left: 6px;
    color: var(--line);
  }

  @media (max-width: 640px) {
    li:last-child {
      display: none;
    }

    li:nth-last-child(2)::after {
      content: "";
      margin-left: 0;
    }
  }
</style>
