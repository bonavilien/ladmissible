---
import ArticleCard from '../components/ArticleCard.astro';
import EditorialBlock from '../components/EditorialBlock.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { categories } from '../data/categories';
import { getFeaturedArticle, getPublishedArticles } from '../lib/content';
import { site } from '../lib/site';

const articles = await getPublishedArticles();
const featuredArticle = await getFeaturedArticle();
const latestArticles = articles.filter((article) => article.id !== featuredArticle?.id).slice(0, 6);
---

<BaseLayout
  title="Ecoles de commerce, admissions et classements"
  description={site.description}
  path="/"
>
  <section class="home-hero section">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Media ecoles de commerce</p>
        <h1 class="hero-title">Les admissions, sans la brume de plaquette.</h1>
        <p class="lede">
          Actualites, guides et classements pour comprendre les ecoles de commerce sans se faire endormir par trois acronymes et une photo de campus.
        </p>
        <p class="scribble-note">A lire avant de cocher une case trop vite.</p>
      </div>
      {
        featuredArticle && (
          <div class="hero-feature">
            <ArticleCard article={featuredArticle} featured />
          </div>
        )
      }
    </div>
  </section>

  <section class="section surface-band" aria-labelledby="categories-title">
    <div class="container">
      <div class="section-head">
        <h2 id="categories-title">Entrer par le bon sujet</h2>
        <p>Pas besoin de subir toute la carte du restaurant quand vous cherchez juste les dates d'oral.</p>
      </div>
      <div class="category-grid">
        {categories.map((category) => (
          <a class="category-link" href={`/categories/${category.slug}/`}>
            <span class="category-mark" aria-hidden="true">#</span>
            <strong>{category.name}</strong>
            <span>{category.description}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="latest-title">
    <div class="container">
      <div class="section-head row">
        <div>
          <h2 id="latest-title">Derniers articles</h2>
          <p>Du concret, du lisible, et juste assez de recul pour ne pas applaudir une annonce par reflexe.</p>
        </div>
        <a class="button-link" href="/articles/">Tous les articles</a>
      </div>
      <div class="grid article-grid">
        {latestArticles.map((article) => <ArticleCard article={article} />)}
      </div>
    </div>
  </section>

  <section class="section closing-band">
    <div class="container">
      <EditorialBlock title="A retenir">
        <p>
          Le MVP doit rester rapide, statique et editorial. Le CMS viendra plus tard; pour l'instant, le contenu structure fait tres bien le travail.
        </p>
      </EditorialBlock>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    padding-top: clamp(36px, 8vw, 88px);
  }

  .home-hero::after {
    content: "anti-brochure";
    position: absolute;
    right: max(16px, calc((100vw - var(--max)) / 2));
    bottom: 12px;
    display: none;
    border: 3px solid var(--accent);
    border-radius: 8px;
    padding: 6px 10px;
    color: var(--accent-dark);
    font-weight: 900;
    transform: rotate(7deg);
  }

  .hero-grid {
    display: grid;
    gap: clamp(28px, 6vw, 72px);
  }

  .hero-feature {
    align-self: end;
  }

  .scribble-note {
    width: fit-content;
    margin: 22px 0 0;
    border: 2px dashed var(--blue-pen);
    border-radius: 12px 18px 14px 20px / 18px 12px 20px 14px;
    padding: 8px 12px;
    color: var(--blue-pen);
    font-weight: 800;
    transform: rotate(-1.2deg);
  }

  .surface-band {
    background:
      linear-gradient(135deg, color-mix(in oklch, var(--marker) 40%, transparent), transparent 42%),
      var(--surface);
    border-block: 2px solid var(--ink);
  }

  .section-head {
    position: relative;
    max-width: 760px;
    margin-bottom: 24px;
  }

  .section-head::after {
    content: "";
    display: block;
    width: min(220px, 58vw);
    height: 10px;
    margin-top: 12px;
    background: var(--marker);
    transform: rotate(-1deg);
  }

  .section-head h2 {
    margin: 0;
    color: var(--ink);
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(1.8rem, 5vw, 3.4rem);
    line-height: 1.05;
  }

  .section-head p {
    margin: 10px 0 0;
    color: var(--muted);
  }

  .section-head.row {
    display: grid;
    gap: 18px;
    max-width: none;
  }

  .category-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .category-link {
    position: relative;
    display: grid;
    gap: 8px;
    border: 2px solid var(--ink);
    border-radius: 14px 20px 12px 18px / 18px 12px 20px 14px;
    padding: 14px;
    background: var(--paper);
    box-shadow: 4px 4px 0 var(--shadow);
    text-decoration: none;
    transform: rotate(-0.5deg);
  }

  .category-link:nth-child(even) {
    transform: rotate(0.6deg);
  }

  .category-mark {
    position: absolute;
    right: 12px;
    top: 6px;
    color: var(--accent);
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
  }

  .category-link strong {
    color: var(--ink);
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1.35rem;
    line-height: 1.05;
  }

  .category-link span {
    color: var(--muted);
  }

  .closing-band {
    padding-top: 0;
  }

  @media (min-width: 860px) {
    .home-hero::after {
      display: block;
    }

    .hero-grid {
      grid-template-columns: minmax(0, 1.55fr) minmax(280px, 0.45fr);
      align-items: end;
    }

    .section-head.row {
      grid-template-columns: 1fr auto;
      align-items: end;
    }

    .article-grid {
      grid-template-columns: 1.15fr 0.85fr 1fr;
    }
  }
</style>
