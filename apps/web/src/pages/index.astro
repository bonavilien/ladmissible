---
import ArticleCard from '../components/ArticleCard.astro';
import EditorialBlock from '../components/EditorialBlock.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { categories } from '../data/categories';
import {
  formatDate,
  getArticleCategory,
  getArticleUrl,
  getFeaturedArticle,
  getPublishedArticles,
} from '../lib/content';
import { site } from '../lib/site';

const articles = await getPublishedArticles();
const featuredArticle = await getFeaturedArticle();
const latestArticles = articles.filter((article) => article.id !== featuredArticle?.id).slice(0, 6);
const featuredCategory = featuredArticle ? getArticleCategory(featuredArticle) : undefined;
const featuredUrl = featuredArticle ? getArticleUrl(featuredArticle) : '';
const typeLabels = {
  article: 'Article',
  news: 'Actu',
  guide: 'Guide',
  analysis: 'Analyse',
};
---

<BaseLayout
  title="Ecoles de commerce, admissions et classements"
  description={site.description}
  path="/"
>

  <section class="home-hero section">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Media ecoles de commerce</p>
        <h1 class="hero-title">
          <span>Les</span>
          <span>admissions,</span>
          <span>sans la brume de plaquette.</span>
        </h1>
        <p class="lede">
          Actualites, guides et classements pour comprendre les ecoles de commerce sans se faire endormir par trois acronymes et une photo de campus.
        </p>
        <p class="scribble-note">A lire avant de cocher une case trop vite.</p>
      </div>
      {
        featuredArticle && (
          <div class="hero-feature">
            <article class="hero-card">
              <a class="hero-card-visual" href={featuredUrl} aria-label={`Lire ${featuredArticle.data.title}`}>
                {
                  featuredArticle.data.image ? (
                    <img
                      src={featuredArticle.data.image}
                      alt={featuredArticle.data.imageAlt ?? featuredArticle.data.title}
                    />
                  ) : (
                    <span>Photo article</span>
                  )
                }
              </a>
              <div class="hero-card-body">
                <div class="card-topline">
                  {
                    featuredCategory && (
                      <a class="category-tag" href={`/categories/${featuredCategory.slug}/`}>
                        {featuredCategory.name}
                      </a>
                    )
                  }
                  <span>{typeLabels[featuredArticle.data.type]}</span>
                </div>
                <h2><a href={featuredUrl}>{featuredArticle.data.title}</a></h2>
                <p>{featuredArticle.data.description}</p>
                <footer class="meta">
                  <span>{formatDate(featuredArticle.data.publishDate)}</span>
                </footer>
              </div>
            </article>
          </div>
        )
      }
    </div>
  </section>


  <section class="section surface-band" aria-labelledby="categories-title">
    <div class="container">
      <div class="section-head">
        <h2 id="categories-title">Entrer par le bon sujet</h2>
        <p>Pas besoin de subir toute la carte du restaurant quand vous cherchez juste les dates d'oral.</p>
      </div>
      <div class="category-grid">
        {categories.map((category) => (
          <a class="category-link" href={`/categories/${category.slug}/`}>
            <span class="category-mark" aria-hidden="true">#</span>
            <strong>{category.name}</strong>
            <span>{category.description}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="latest-title">
    <div class="container">
      <div class="section-head row">
        <div>
          <h2 id="latest-title">Derniers articles</h2>
          <p>Du concret, du lisible, et juste assez de recul pour ne pas applaudir une annonce par reflexe.</p>
        </div>
        <a class="button-link" href="/articles/">Tous les articles</a>
      </div>
      <div class="grid article-grid">
        {latestArticles.map((article) => <ArticleCard article={article} />)}
      </div>
    </div>
  </section>

  <section class="section closing-band">
    <div class="container">
      <EditorialBlock title="A retenir">
        <p>
          Le MVP doit rester rapide, statique et editorial. Le CMS viendra plus tard; pour l'instant, le contenu structure fait tres bien le travail.
        </p>
      </EditorialBlock>
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    padding-top: clamp(36px, 7vw, 72px);
  }

  .home-hero::after {
    content: "anti-brochure";
    position: absolute;
    right: max(16px, calc((100vw - var(--max)) / 2));
    bottom: 12px;
    display: none;
    border: 3px solid var(--accent);
    border-radius: 8px;
    padding: 6px 10px;
    color: var(--accent-dark);
    font-weight: 900;
    transform: rotate(7deg);
  }

  .hero-grid {
    display: grid;
    gap: clamp(28px, 6vw, 64px);
  }

  .hero-feature {
    align-self: end;
  }

  .home-hero .hero-title {
    font-size: clamp(2.2rem, 9vw, 6.15rem);
    line-height: 0.92;
  }

  .home-hero .hero-title span {
    display: block;
  }

  .home-hero .hero-title span:nth-child(2) {
    white-space: nowrap;
  }


  .hero-card {
    position: relative;
    display: grid;
    gap: 14px;
    border: 2px solid var(--ink);
    border-radius: 18px 12px 20px 14px / 14px 20px 12px 18px;
    padding: 16px;
    background: var(--paper);
    box-shadow: 7px 7px 0 var(--shadow);
    transform: rotate(0.6deg);
    transition:
      box-shadow 180ms var(--ease-out),
      transform 180ms var(--ease-out);
  }

  .hero-card:hover,
  .hero-card:focus-within {
    box-shadow: 9px 9px 0 var(--shadow);
    transform: rotate(0deg) translate(-1px, -1px);
  }

  .hero-card::before {
    content: "";
    position: absolute;
    top: -11px;
    left: 24px;
    width: 76px;
    height: 19px;
    border: 1px solid color-mix(in oklch, var(--ink) 30%, transparent);
    background: color-mix(in oklch, var(--marker) 40%, var(--paper));
    transform: rotate(-2deg);
  }

  .hero-card-visual {
    display: grid;
    min-height: clamp(160px, 28vw, 240px);
    place-items: end start;
    overflow: hidden;
    border: 2px solid var(--ink);
    border-radius: 12px 18px 10px 16px / 16px 10px 18px 12px;
    background:
      linear-gradient(135deg, color-mix(in oklch, var(--marker) 24%, transparent), transparent 46%),
      linear-gradient(150deg, color-mix(in oklch, var(--blue-pen) 13%, var(--paper)), var(--paper));
    color: var(--ink);
    font-weight: 900;
    text-decoration: none;
  }

  .hero-card-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-card-visual span {
    padding: 12px;
  }

  .hero-card-body {
    display: grid;
    gap: 14px;
  }

  .card-topline {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    justify-content: space-between;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .hero-card h2 {
    margin: 0;
    color: var(--ink);
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(1.7rem, 4vw, 2.45rem);
    line-height: 1.02;
    text-wrap: balance;
  }

  .hero-card h2 a {
    text-decoration: none;
  }

  .hero-card h2 a:hover {
    text-decoration: underline;
    text-decoration-color: var(--marker);
    text-decoration-thickness: 0.25em;
    text-underline-offset: -0.12em;
    text-decoration-skip-ink: none;
  }

  .hero-card p {
    margin: 0;
    color: var(--muted);
    text-wrap: pretty;
  }

  .hero-card footer {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
  }

  .scribble-note {
    width: fit-content;
    margin: 22px 0 0;
    border: 2px dashed var(--blue-pen);
    border-radius: 12px 18px 14px 20px / 18px 12px 20px 14px;
    padding: 8px 12px;
    color: var(--blue-pen);
    font-weight: 800;
    transform: rotate(-1.2deg);
  }

  .surface-band {
    background:
      linear-gradient(135deg, color-mix(in oklch, var(--marker) 18%, transparent), transparent 42%),
      var(--surface);
    border-block: 2px solid var(--ink);
  }

  .section-head {
    position: relative;
    max-width: 760px;
    margin-bottom: 24px;
  }

  .section-head::after {
    content: "";
    display: block;
    width: min(220px, 58vw);
    height: 10px;
    margin-top: 12px;
    background: var(--marker);
    transform: rotate(-1deg);
  }

  .section-head h2 {
    margin: 0;
    color: var(--ink);
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(1.8rem, 5vw, 3.4rem);
    line-height: 1.05;
  }

  .section-head p {
    margin: 10px 0 0;
    color: var(--muted);
  }

  .section-head.row {
    display: grid;
    gap: 18px;
    max-width: none;
  }

  .category-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .category-link {
    position: relative;
    display: grid;
    gap: 8px;
    border: 2px solid var(--ink);
    border-radius: 14px 20px 12px 18px / 18px 12px 20px 14px;
    padding: 14px;
    background: var(--paper);
    box-shadow: 4px 4px 0 var(--shadow);
    text-decoration: none;
    transform: rotate(-0.5deg);
    transition:
      box-shadow 180ms var(--ease-out),
      transform 180ms var(--ease-out);
  }

  .category-link:nth-child(even) {
    transform: rotate(0.6deg);
  }

  .category-link:hover,
  .category-link:focus-visible {
    color: var(--ink);
    box-shadow: 6px 6px 0 var(--shadow);
    transform: rotate(0deg) translate(-1px, -1px);
  }

  .category-mark {
    position: absolute;
    right: 12px;
    top: 6px;
    color: var(--marker-dark);
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
  }

  .category-link strong {
    color: var(--ink);
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1.35rem;
    line-height: 1.05;
  }

  .category-link span:not(.category-mark) {
    color: var(--muted);
  }

  .closing-band {
    padding-top: 0;
  }

  @media (min-width: 860px) {
    .home-hero::after {
      display: block;
    }

    .hero-grid {
      grid-template-columns: minmax(0, 1.12fr) minmax(330px, 0.88fr);
      align-items: end;
    }

    .section-head.row {
      grid-template-columns: 1fr auto;
      align-items: end;
    }

    .article-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
