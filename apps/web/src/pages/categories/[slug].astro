---
import ArticleCard from '../../components/ArticleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categories } from '../../data/categories';
import { getAllTags, getArticlesByCategory, getPublishedArticles } from '../../lib/content';
import { buildBreadcrumbJsonLd, buildCollectionPageJsonLd } from '../../lib/seo';
import { withBase } from '../../lib/site';

export async function getStaticPaths() {
  return categories.map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const articles = await getArticlesByCategory(category.slug);
const allArticles = await getPublishedArticles();
const categoryTags = getAllTags(articles).slice(0, 10);
const siblingCategories = categories.filter((item) => item.slug !== category.slug);
const breadcrumbs = [
  { name: 'Accueil', path: '/' },
  { name: 'Articles', path: '/articles/' },
  { name: category.name, path: `/categories/${category.slug}/` },
];
const pagePath = `/categories/${category.slug}/`;
---

<BaseLayout
  title={category.seoTitle}
  description={category.seoDescription}
  path={pagePath}
  jsonLd={[
    buildCollectionPageJsonLd({
      title: category.seoTitle,
      description: category.seoDescription,
      path: pagePath,
    }),
    buildBreadcrumbJsonLd(breadcrumbs),
  ]}
>
  <section class="section">
    <div class="container">
      <Breadcrumbs items={breadcrumbs} />
      <header class="category-header">
        <p class="eyebrow">Dossier de redaction</p>
        <h1 class="page-title">{category.name}</h1>
        <p class="lede">{category.intro}</p>
      </header>
      <nav class="filter-panel" aria-label="Filtres de rubrique">
        <div>
          <p class="filter-label">Rubriques</p>
          <div class="filter-list">
            <a class="category-tag active" href={withBase(`/categories/${category.slug}/`)} aria-current="page">
              {category.name}
            </a>
            {siblingCategories.map((item) => (
              <a class="category-tag" href={withBase(`/categories/${item.slug}/`)}>{item.name}</a>
            ))}
          </div>
        </div>
        {
          categoryTags.length > 0 && (
            <div>
              <p class="filter-label">Tags de cette rubrique</p>
              <div class="filter-list">
                {categoryTags.map((tag) => (
                  <a class="tag-link" href={withBase(`/tags/${tag.slug}/`)}>
                    #{tag.name}
                    <span>{tag.count}</span>
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </nav>
      {
        articles.length > 0 ? (
          <div class="grid article-grid">
            {articles.map((article) => <ArticleCard article={article} />)}
          </div>
        ) : (
          <p class="empty">Rien a lire ici pour l'instant. Le silence, mais version SEO propre.</p>
        )
      }
      <aside class="internal-links" aria-labelledby="internal-links-title">
        <h2 id="internal-links-title">Continuer le tri</h2>
        <div class="filter-list">
          <a class="button-secondary" href={withBase("/articles/")}>Tous les articles</a>
          {allArticles.length > articles.length && <a class="button-secondary" href={withBase("/tags/")}>Tous les tags</a>}
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .category-header {
    position: relative;
    margin: 28px 0 clamp(32px, 6vw, 64px);
    border: 2px solid var(--ink);
    border-radius: 22px 14px 18px 16px / 14px 20px 12px 22px;
    padding: clamp(18px, 4vw, 34px);
    background:
      linear-gradient(105deg, transparent 0 58%, color-mix(in oklch, var(--marker) 22%, transparent) 58% 100%),
      var(--paper);
    box-shadow: 7px 7px 0 var(--shadow);
    transform: rotate(-0.3deg);
  }

  .category-header::before {
    content: "rubrique";
    position: absolute;
    right: 18px;
    top: -18px;
    border: 2px solid var(--accent);
    border-radius: 8px;
    padding: 4px 8px;
    background: var(--paper);
    color: var(--accent-dark);
    font-weight: 900;
    transform: rotate(5deg);
  }

  .empty {
    max-width: 680px;
    color: var(--muted);
  }

  .filter-panel,
  .internal-links {
    display: grid;
    gap: 16px;
    margin-bottom: clamp(24px, 5vw, 42px);
  }

  .filter-label {
    margin: 0 0 8px;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .filter-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .category-tag.active {
    background: var(--marker);
    color: var(--ink);
  }

  .tag-link {
    display: inline-flex;
    gap: 6px;
    align-items: center;
    border: 1px dashed var(--blue-pen);
    border-radius: var(--radius-pill);
    padding: 5px 10px;
    color: var(--blue-pen);
    font-size: 0.9rem;
    font-weight: 900;
    text-decoration: none;
  }

  .tag-link span {
    color: var(--muted);
    font-size: 0.78rem;
  }

  .internal-links {
    max-width: 760px;
    margin-top: clamp(28px, 6vw, 56px);
    margin-bottom: 0;
  }

  .internal-links h2 {
    margin: 0;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    line-height: 1.05;
  }
</style>
