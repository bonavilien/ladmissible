---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import BaseLayout from './BaseLayout.astro';
import {
  formatDate,
  getArticleCategory,
  getArticleHeadings,
  getArticleUrl,
  getArticleSlug,
  getTagUrl,
  getReadingTimeMinutes,
} from '../lib/content';
import { buildArticleJsonLd, buildBreadcrumbJsonLd } from '../lib/seo';
import type { Article } from '../lib/content';

type Props = {
  article: Article;
  relatedArticles?: Article[];
};

const { article, relatedArticles = [] } = Astro.props;
const category = getArticleCategory(article);
const slug = getArticleSlug(article);
const path = `/articles/${slug}/`;
const readingTime = getReadingTimeMinutes(article);
const headings = getArticleHeadings(article);
const showToc = headings.length >= 3;
const typeLabels = {
  article: 'Article',
  news: 'Actu',
  guide: 'Guide',
  analysis: 'Analyse',
};
const kickerLabels = {
  article: 'article annote',
  news: 'actu a verifier',
  guide: 'guide pratique',
  analysis: 'analyse sans vernis',
};
const breadcrumbs = [
  { name: 'Accueil', path: '/' },
  { name: 'Articles', path: '/articles/' },
  category ? { name: category.name, path: `/categories/${category.slug}/` } : undefined,
  { name: article.data.title, path },
].filter(Boolean) as Array<{ name: string; path: string }>;
---

<BaseLayout
  title={article.data.title}
  description={article.data.description}
  path={path}
  image={article.data.image}
  type="article"
  jsonLd={[buildArticleJsonLd(article), buildBreadcrumbJsonLd(breadcrumbs)]}
>
  <article class="article-shell">
    <div class="container">
      <Breadcrumbs items={breadcrumbs} />
      <header class="article-header">
        <div class="article-kicker">
          {category && <p class="eyebrow">{category.name}</p>}
          <span>{kickerLabels[article.data.type]}</span>
        </div>
        <h1 class="article-title">{article.data.title}</h1>
        <p class="article-chapo">{article.data.description}</p>
        <dl class="article-meta" aria-label="Informations de publication">
          <div>
            <dt>Auteur</dt>
            <dd>{article.data.author}</dd>
          </div>
          <div>
            <dt>Publication</dt>
            <dd>{formatDate(article.data.publishDate)}</dd>
          </div>
          {
            article.data.updatedDate && (
              <div>
                <dt>Mise a jour</dt>
                <dd>{formatDate(article.data.updatedDate)}</dd>
              </div>
            )
          }
          <div>
            <dt>Lecture</dt>
            <dd>{readingTime} min</dd>
          </div>
        </dl>
        {
          article.data.tags.length > 0 && (
            <nav class="article-tags" aria-label="Tags de l'article">
              {article.data.tags.map((tag) => (
                <a class="tag-link" href={getTagUrl(tag)}>#{tag}</a>
              ))}
            </nav>
          )
        }
      </header>
      {
        article.data.image && (
          <figure class="article-image">
            <img src={article.data.image} alt={article.data.imageAlt ?? ''} loading="eager" />
            {article.data.imageAlt && <figcaption>{article.data.imageAlt}</figcaption>}
          </figure>
        )
      }
      {
        !article.data.image && (
          <section class="article-visual" aria-label="Repere editorial">
            <div class="visual-note">
              <span>Fiche rapide</span>
              <strong>{category?.name ?? 'Article'}</strong>
              <p>
                Les points sensibles restent balises: dates, frais, epreuves et chiffres
                demandent une verification a la source.
              </p>
            </div>
            <dl class="visual-facts">
              <div>
                <dt>Format</dt>
                <dd>{typeLabels[article.data.type]}</dd>
              </div>
              <div>
                <dt>Lecture</dt>
                <dd>{readingTime} min</dd>
              </div>
              <div>
                <dt>Sources</dt>
                <dd>{article.data.sources.length || 'a verifier'}</dd>
              </div>
            </dl>
          </section>
        )
      }
      <div class="article-body">
        <div class="article-main">
          {
            showToc && (
              <nav class="toc" aria-labelledby="toc-title">
                <h2 id="toc-title">Sommaire</h2>
                <ol>
                  {headings.map((heading) => (
                    <li>
                      <a href={`#${heading.id}`}>{heading.text}</a>
                    </li>
                  ))}
                </ol>
              </nav>
            )
          }
          <div class="prose">
            <slot />
          </div>
        </div>
        <aside class="article-rail" aria-label="Complements de lecture">
          <div class="rail-card">
            <h2>En bref</h2>
            <dl>
              <div>
                <dt>Rubrique</dt>
                <dd>{category?.name ?? 'Article'}</dd>
              </div>
              <div>
                <dt>Type</dt>
                <dd>{typeLabels[article.data.type]}</dd>
              </div>
              <div>
                <dt>Lecture</dt>
                <dd>{readingTime} min</dd>
              </div>
            </dl>
          </div>
          {
            article.data.sources.length > 0 && (
              <div class="sources rail-card" aria-labelledby="sources-title">
                <h2 id="sources-title">Sources a verifier</h2>
                <ul>
                  {article.data.sources.map((source) => (
                    <li>
                      <a href={source.url} rel="noopener" target="_blank">{source.label}</a>
                      <span>Consultee le {formatDate(source.checkedAt)}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )
          }
        </aside>
        {
          relatedArticles.length > 0 && (
            <aside class="related-articles" aria-labelledby="related-title">
              <div class="related-head">
                <p class="eyebrow">Lire aussi</p>
                <h2 id="related-title">Articles lies</h2>
              </div>
              <ol class="related-list">
                {relatedArticles.map((relatedArticle) => {
                  const relatedCategory = getArticleCategory(relatedArticle);

                  return (
                    <li>
                      <a href={getArticleUrl(relatedArticle)}>
                        <span>{relatedCategory?.name ?? typeLabels[relatedArticle.data.type]}</span>
                        <strong>{relatedArticle.data.title}</strong>
                        <time datetime={relatedArticle.data.publishDate.toISOString()}>
                          {formatDate(relatedArticle.data.publishDate)}
                        </time>
                      </a>
                    </li>
                  );
                })}
              </ol>
            </aside>
          )
        }
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article-shell {
    padding-block: 28px clamp(44px, 8vw, 88px);
  }

  .article-header {
    position: relative;
    max-width: 920px;
    padding-block: clamp(24px, 6vw, 64px);
    border-bottom: 3px solid var(--ink);
  }

  .article-header::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: -8px;
    width: min(260px, 55vw);
    height: 14px;
    background: var(--marker);
    transform: rotate(-1.5deg);
  }

  .article-kicker {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }

  .article-kicker span {
    color: var(--marker-dark);
    font-weight: 900;
    transform: rotate(1.5deg);
  }

  .article-chapo {
    max-width: 760px;
    margin: 18px 0 0;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(1.18rem, 2.4vw, 1.55rem);
    line-height: 1.35;
    text-wrap: pretty;
  }

  .article-meta {
    display: grid;
    gap: 10px;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    max-width: 760px;
    margin: 24px 0 0;
  }

  .article-meta div {
    border-top: 2px solid color-mix(in oklch, var(--ink) 55%, transparent);
    padding-top: 8px;
  }

  .article-meta dt,
  .article-meta dd {
    margin: 0;
  }

  .article-meta dt {
    color: var(--marker-dark);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .article-meta dd {
    color: var(--muted);
    font-size: 0.95rem;
    font-weight: 800;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    max-width: 760px;
    margin-top: 18px;
  }

  .tag-link {
    display: inline-flex;
    align-items: center;
    border: 1px dashed var(--blue-pen);
    border-radius: var(--radius-pill);
    padding: 5px 10px;
    color: var(--blue-pen);
    font-size: 0.9rem;
    font-weight: 900;
    text-decoration: none;
  }

  .tag-link:hover {
    background: color-mix(in oklch, var(--blue-pen) 10%, var(--paper));
    color: var(--ink);
  }

  .article-image {
    margin: 28px 0 0;
    border: 2px solid var(--ink);
    border-radius: 18px 12px 22px 14px / 12px 22px 14px 18px;
    padding: 8px;
    background: var(--paper);
    box-shadow: 7px 7px 0 var(--shadow);
    transform: rotate(-0.4deg);
  }

  .article-image img {
    width: 100%;
    border-radius: 10px 8px 12px 9px / 8px 12px 9px 10px;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .article-image figcaption {
    margin-top: 8px;
    color: var(--blue-pen);
    font-size: 0.9rem;
    font-weight: 800;
  }

  .article-visual {
    position: relative;
    display: grid;
    gap: 18px;
    margin-top: clamp(24px, 5vw, 46px);
    border: 2px solid var(--ink);
    border-radius: 24px 14px 20px 16px / 14px 24px 16px 20px;
    padding: clamp(18px, 4vw, 32px);
    background:
      linear-gradient(115deg, transparent 0 48%, color-mix(in oklch, var(--marker) 28%, transparent) 48% 100%),
      var(--paper);
    box-shadow: 8px 8px 0 var(--shadow);
    overflow: hidden;
  }

  .article-visual::before,
  .article-visual::after {
    content: "";
    position: absolute;
    border: 2px solid color-mix(in oklch, var(--ink) 52%, transparent);
    pointer-events: none;
  }

  .article-visual::before {
    right: clamp(18px, 6vw, 70px);
    top: 18px;
    width: clamp(70px, 18vw, 150px);
    height: clamp(44px, 10vw, 86px);
    border-radius: 48% 52% 45% 55%;
    transform: rotate(-7deg);
  }

  .article-visual::after {
    right: clamp(48px, 12vw, 190px);
    bottom: 20px;
    width: clamp(42px, 10vw, 84px);
    height: clamp(42px, 10vw, 84px);
    border-radius: 50%;
    transform: rotate(8deg);
  }

  .visual-note {
    position: relative;
    z-index: 1;
    max-width: 620px;
  }

  .visual-note span {
    display: inline-flex;
    margin-bottom: 10px;
    border: 1px dashed var(--blue-pen);
    border-radius: var(--radius-pill);
    padding: 3px 9px;
    color: var(--blue-pen);
    font-size: 0.82rem;
    font-weight: 900;
  }

  .visual-note strong {
    display: block;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(2rem, 7vw, 4.8rem);
    font-weight: 900;
    line-height: 0.95;
  }

  .visual-note p {
    max-width: 560px;
    margin: 14px 0 0;
    color: var(--muted);
    font-weight: 800;
  }

  .visual-facts {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 10px;
    margin: 0;
  }

  .visual-facts div {
    border-top: 2px solid color-mix(in oklch, var(--ink) 50%, transparent);
    padding-top: 8px;
  }

  .visual-facts dt,
  .visual-facts dd {
    margin: 0;
  }

  .visual-facts dt {
    color: var(--marker-dark);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .visual-facts dd {
    color: var(--ink);
    font-weight: 900;
  }

  .article-body {
    display: grid;
    gap: clamp(28px, 5vw, 44px);
    padding-top: clamp(28px, 5vw, 56px);
  }

  .article-main {
    display: grid;
    gap: 24px;
  }

  .toc {
    max-width: 760px;
    border: 2px solid var(--ink);
    border-radius: 16px 12px 18px 14px / 12px 18px 14px 16px;
    padding: 16px;
    background: color-mix(in oklch, var(--marker) 18%, var(--paper));
    box-shadow: 4px 4px 0 var(--shadow);
  }

  .toc h2 {
    margin: 0 0 10px;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.05;
  }

  .toc ol {
    display: grid;
    gap: 8px;
    margin: 0;
    padding-left: 1.2rem;
  }

  .toc a {
    color: var(--ink);
    font-weight: 800;
    text-decoration-color: var(--marker-dark);
  }

  .sources {
    background: var(--surface);
  }

  .article-rail {
    display: grid;
    align-content: start;
    gap: 16px;
  }

  .rail-card {
    border: 2px solid var(--ink);
    border-radius: 16px 12px 18px 14px / 12px 18px 14px 16px;
    padding: 18px;
    background: var(--paper);
    box-shadow: 5px 5px 0 var(--shadow);
  }

  .rail-card h2 {
    margin: 0 0 12px;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.05;
  }

  .rail-card dl {
    display: grid;
    gap: 10px;
    margin: 0;
  }

  .rail-card dl div {
    border-top: 1px solid color-mix(in oklch, var(--ink) 35%, transparent);
    padding-top: 8px;
  }

  .rail-card dt,
  .rail-card dd {
    margin: 0;
  }

  .rail-card dt {
    color: var(--marker-dark);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .rail-card dd {
    color: var(--muted);
    font-weight: 800;
  }

  .sources ul {
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .sources li {
    display: grid;
    gap: 2px;
  }

  .sources span {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .related-articles {
    grid-column: 1 / -1;
    display: grid;
    gap: 18px;
    border-top: 3px solid var(--ink);
    padding-top: clamp(22px, 4vw, 34px);
  }

  .related-head {
    max-width: 760px;
  }

  .related-head h2 {
    margin: 0;
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 5vw, 3rem);
    line-height: 1.05;
  }

  .related-list {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .related-list li {
    border-top: 1px solid color-mix(in oklch, var(--ink) 35%, transparent);
  }

  .related-list li:last-child {
    border-bottom: 1px solid color-mix(in oklch, var(--ink) 35%, transparent);
  }

  .related-list a {
    display: grid;
    gap: 6px;
    padding: 16px 0;
    color: var(--ink);
    text-decoration: none;
  }

  .related-list a:hover strong {
    text-decoration: underline;
    text-decoration-color: var(--marker);
    text-decoration-thickness: 0.25em;
    text-underline-offset: -0.12em;
    text-decoration-skip-ink: none;
  }

  .related-list span,
  .related-list time {
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 900;
  }

  .related-list strong {
    max-width: 820px;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 2rem);
    line-height: 1.08;
  }

  @media (min-width: 980px) {
    .article-visual {
      grid-template-columns: minmax(0, 1fr) 220px;
      align-items: end;
    }

    .visual-facts {
      align-self: end;
    }

    .article-body {
      grid-template-columns: minmax(0, 760px) minmax(220px, 300px);
      align-items: start;
      column-gap: clamp(36px, 6vw, 64px);
    }

    .article-rail {
      position: sticky;
      top: 118px;
    }
  }
</style>
