---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import BaseLayout from './BaseLayout.astro';
import { formatDate, getArticleCategory, getArticleSlug } from '../lib/content';
import { buildArticleJsonLd, buildBreadcrumbJsonLd } from '../lib/seo';
import type { Article } from '../lib/content';

type Props = {
  article: Article;
};

const { article } = Astro.props;
const category = getArticleCategory(article);
const slug = getArticleSlug(article);
const path = `/articles/${slug}/`;
const breadcrumbs = [
  { name: 'Accueil', path: '/' },
  { name: 'Articles', path: '/articles/' },
  category ? { name: category.name, path: `/categories/${category.slug}/` } : undefined,
  { name: article.data.title, path },
].filter(Boolean) as Array<{ name: string; path: string }>;
---

<BaseLayout
  title={article.data.title}
  description={article.data.description}
  path={path}
  image={article.data.image}
  type="article"
  jsonLd={[buildArticleJsonLd(article), buildBreadcrumbJsonLd(breadcrumbs)]}
>
  <article class="article-shell">
    <div class="container">
      <Breadcrumbs items={breadcrumbs} />
      <header class="article-header">
        {category && <p class="eyebrow">{category.name}</p>}
        <h1 class="article-title">{article.data.title}</h1>
        <p class="lede">{article.data.description}</p>
        <p class="meta">
          Par {article.data.author} · Publie le {formatDate(article.data.publishDate)}
          {
            article.data.updatedDate &&
              ` · Mis a jour le ${formatDate(article.data.updatedDate)}`
          }
        </p>
      </header>
      {
        article.data.image && (
          <figure class="article-image">
            <img src={article.data.image} alt={article.data.imageAlt ?? ''} loading="eager" />
            {article.data.imageAlt && <figcaption>{article.data.imageAlt}</figcaption>}
          </figure>
        )
      }
      <div class="article-body">
        <div class="prose">
          <slot />
        </div>
        {
          article.data.sources.length > 0 && (
            <aside class="sources" aria-labelledby="sources-title">
              <h2 id="sources-title">Sources</h2>
              <ul>
                {article.data.sources.map((source) => (
                  <li>
                    <a href={source.url}>{source.label}</a>
                    <span>Verifie le {formatDate(source.checkedAt)}</span>
                  </li>
                ))}
              </ul>
            </aside>
          )
        }
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article-shell {
    padding-block: 28px clamp(44px, 8vw, 88px);
  }

  .article-header {
    max-width: 920px;
    padding-block: clamp(28px, 6vw, 72px);
    border-bottom: 1px solid var(--line);
  }

  .article-image {
    margin: 28px 0 0;
  }

  .article-image img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .article-image figcaption {
    margin-top: 8px;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .article-body {
    display: grid;
    gap: 32px;
    padding-top: clamp(28px, 5vw, 56px);
  }

  .sources {
    max-width: 760px;
    border-top: 1px solid var(--line);
    padding-top: 20px;
  }

  .sources h2 {
    margin: 0 0 12px;
    font-size: 1rem;
  }

  .sources ul {
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .sources li {
    display: grid;
    gap: 2px;
  }

  .sources span {
    color: var(--muted);
    font-size: 0.9rem;
  }
</style>
